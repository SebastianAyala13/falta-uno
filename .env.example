# Credenciales de Supabase para Falta Uno
# Copiá este archivo como `.env` y pegá tus valores reales.
# Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI

# ── Pagos online con Lemon Squeezy ───────────────────────────────────────────
# Poné cualquier valor (ej. 1) para MOSTRAR el medio de pago online en la app.
# Dejalo vacío/comentado mientras las Edge Functions no estén desplegadas.
# EXPO_PUBLIC_LEMONSQUEEZY_ENABLED=1

# Las siguientes son SECRETAS y van SOLO en Supabase Edge Functions (nunca en
# la app ni con prefijo EXPO_PUBLIC_). Se configuran con:
#   supabase secrets set LEMONSQUEEZY_API_KEY=... LEMONSQUEEZY_STORE_ID=... \
#     LEMONSQUEEZY_VARIANT_ID=... LEMONSQUEEZY_WEBHOOK_SECRET=...
# LEMONSQUEEZY_API_KEY=            # Settings → API en lemonsqueezy.com
# LEMONSQUEEZY_STORE_ID=           # id numérico de tu tienda
# LEMONSQUEEZY_VARIANT_ID=         # variante del producto "Cupo de partido"
# LEMONSQUEEZY_WEBHOOK_SECRET=     # Signing secret del webhook (Settings → Webhooks)

# Credenciales de Supabase para Falta Uno
# Copiá este archivo como `.env` y pegá tus valores reales.
# Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI

# ── URL pública del sitio (app web + páginas legales) ─────────────────────────
# Dominio donde Dokploy sirve la web y las páginas legales.
# La app deriva LEGAL_URL = <SITE_URL>/legal para privacidad y términos.
# Vacío/sin definir = cae al hosting actual en GitHub Pages.
# EXPO_PUBLIC_SITE_URL=https://falta-uno.tudominio.com

# ── Pagos online con PayU (PSP colombiano · Nequi, PSE, tarjeta) ─────────────
# Poné cualquier valor (ej. 1) para MOSTRAR el medio de pago online en la app.
# Dejalo vacío/comentado mientras las Edge Functions no estén desplegadas: la
# app queda solo-efectivo. Ver docs/PAYU-SETUP.md.
# EXPO_PUBLIC_PAYU_ENABLED=1

# Las siguientes son SECRETAS y van SOLO en Supabase Edge Functions (nunca en la
# app ni con prefijo EXPO_PUBLIC_). Las obtenés en el panel de PayU. Deploy:
#   supabase functions deploy payu-crear-transaccion
#   supabase functions deploy payu-webhook --no-verify-jwt
#   supabase secrets set PAYU_API_KEY=... PAYU_MERCHANT_ID=... PAYU_ACCOUNT_ID=... \
#     PAYU_CHECKOUT_URL=... PAYU_RESPONSE_URL=...
# PAYU_API_KEY=                # apiKey del comercio (autenticación de la firma)
# PAYU_MERCHANT_ID=            # id del comercio en PayU
# PAYU_ACCOUNT_ID=             # id de la cuenta (COP)
# PAYU_CHECKOUT_URL=           # URL del WebCheckout (sandbox o producción)
# PAYU_RESPONSE_URL=           # a dónde vuelve el usuario tras pagar
# Registrá la URL de confirmación en PayU apuntando a la función payu-webhook.

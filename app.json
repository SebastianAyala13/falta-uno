{
  "expo": {
    "name": "Falta Uno",
    "slug": "falta-uno",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/logo.png",
    "scheme": "faltauno",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#10B981",
    "assetBundlePatterns": ["**/*"],
    "runtimeVersion": { "policy": "appVersion" },
    "ios": {
      "icon": "./assets/brand/logo.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.faltauno.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Falta Uno usa tus fotos para tu avatar de perfil y la foto de la cancha.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.faltauno.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "backgroundColor": "#0B0F0D",
        "foregroundImage": "./assets/brand/logo.png"
      },
      "permissions": ["READ_MEDIA_IMAGES"],
      "config": {
        "googleMaps": {
          "apiKey": "TU_GOOGLE_MAPS_ANDROID_API_KEY"
        }
      }
    },
    "web": {
      "output": "single",
      "favicon": "./assets/brand/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B0F0D"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Falta Uno usa tus fotos para tu avatar de perfil y la foto de la cancha."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    }
  }
}

# Credenciales de Supabase para Falta Uno
# Copiá este archivo como `.env` y pegá tus valores reales.
# Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY_AQUI

# ── URL pública del sitio (app web + páginas legales) ─────────────────────────
# Dominio donde Dokploy sirve la web y las páginas legales.
# La app deriva LEGAL_URL = <SITE_URL>/legal para privacidad y términos.
# Vacío/sin definir = cae al hosting actual en GitHub Pages.
# EXPO_PUBLIC_SITE_URL=https://falta-uno.tudominio.com

# ── Pagos online con Wompi (PSP colombiano · partidos y canchas) ──────────────
# Poné cualquier valor (ej. 1) para MOSTRAR el medio de pago online en la app.
# Dejalo vacío/comentado mientras las Edge Functions no estén desplegadas.
# EXPO_PUBLIC_WOMPI_ENABLED=1

# Las siguientes son SECRETAS y van SOLO en Supabase Edge Functions (nunca en la
# app ni con prefijo EXPO_PUBLIC_). Las obtenés en comercios.wompi.co. Deploy:
#   supabase functions deploy wompi-crear-transaccion
#   supabase functions deploy wompi-webhook --no-verify-jwt
#   supabase secrets set WOMPI_PUBLIC_KEY=... WOMPI_INTEGRITY_SECRET=... \
#     WOMPI_EVENTS_SECRET=... WOMPI_REDIRECT_URL=...
# WOMPI_PUBLIC_KEY=            # llave pública (pub_prod_... / pub_test_...)
# WOMPI_INTEGRITY_SECRET=      # secreto de integridad (para firmar el checkout)
# WOMPI_EVENTS_SECRET=         # secreto de eventos (para verificar el webhook)
# WOMPI_REDIRECT_URL=          # a dónde vuelve el usuario tras pagar (opcional)
# Usá las llaves de SANDBOX (pub_test_/prv_test_) para probar sin plata real.
# Registrá el webhook en Wompi apuntando a la URL de la función wompi-webhook.

# ── (Legado) Lemon Squeezy — reemplazado por Wompi ───────────────────────────
# EXPO_PUBLIC_LEMONSQUEEZY_ENABLED=1

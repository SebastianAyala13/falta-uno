# ============================================================================
# Credenciales para migrar/desplegar a Supabase en automático.
# COPIÁ este archivo como  .supabase-deploy.env  y completá tus valores.
# Ese archivo queda SOLO en tu PC (está gitignoreado) y NUNCA se pega en el chat.
# Luego se corre:  node scripts/supabase-setup.mjs   (o: pnpm supa:setup)
# ============================================================================

# 1) Conexión a la base (para aplicar supabase/schema.sql).
#    Supabase → Settings → Database → Connection string → "Session pooler" (URI).
#    Usá el SESSION POOLER (host aws-*.pooler.supabase.com): tiene certificado
#    de confianza (TLS verificado) y soporta DDL. Reemplazá [PASSWORD].
SUPABASE_DB_URL=postgresql://postgres.gwkzcjgsuxgqejaukbse:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# (Opcional) Si usás la conexión DIRECTA (db.<ref>.supabase.co), bajá la CA de
# Supabase (Settings → Database → SSL) y apuntá acá su ruta:
# SUPABASE_CA_CERT=C:\ruta\prod-ca-2021.crt

# 2) Token para desplegar Edge Functions y cargar secretos.
#    Supabase → Account → Access Tokens → Generate new token.
SUPABASE_ACCESS_TOKEN=sbp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 3) Llaves de Wompi (se cargan como secretos de las Edge Functions).
#    Wompi → Desarrollo. La pública NO es secreta; integrity/events SÍ.
WOMPI_PUBLIC_KEY=pub_prod_fESunI30KB6pKsQKQuAuo5aWUB30rpNx
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_REDIRECT_URL=https://sebastianayala13.github.io/falta-uno-legal
